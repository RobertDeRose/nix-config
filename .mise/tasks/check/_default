#!/usr/bin/env bash
# [MISE] description="Run every repository validation check"

set -euo pipefail

TASK_FILE="${BASH_SOURCE[0]}"
REPO_ROOT="$(git -C "$(dirname "$TASK_FILE")" rev-parse --show-toplevel)"
cd "$REPO_ROOT"

for task in shell nix inventory packages hosts tests; do
  mise run "check:$task"
done
