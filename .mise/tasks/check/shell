#!/usr/bin/env bash
# [MISE] description="Validate and lint Bash file tasks and libraries"

set -euo pipefail

TASK_FILE="${BASH_SOURCE[0]}"
REPO_ROOT="$(git -C "$(dirname "$TASK_FILE")" rev-parse --show-toplevel)"
cd "$REPO_ROOT"

while IFS= read -r file; do bash -n "$file"; done < <(find .mise bootstrap.sh tests/tasks -type f -name '*.sh' -o -path '.mise/tasks/*' 2>/dev/null | sort)
if command -v shellcheck >/dev/null 2>&1; then
  find .mise tests/tasks -type f -print0 | xargs -0 shellcheck bootstrap.sh
else
  printf 'warning: shellcheck is not installed; syntax checks completed\n' >&2
fi
if command -v shfmt >/dev/null 2>&1; then
  find .mise tests/tasks -type f -print0 | xargs -0 shfmt -d bootstrap.sh
else
  printf 'warning: shfmt is not installed; formatting check skipped\n' >&2
fi
