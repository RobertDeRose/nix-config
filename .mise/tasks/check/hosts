#!/usr/bin/env bash
# [MISE] description="Evaluate every configured host output"

set -euo pipefail

TASK_FILE="${BASH_SOURCE[0]}"
REPO_ROOT="$(git -C "$(dirname "$TASK_FILE")" rev-parse --show-toplevel)"
cd "$REPO_ROOT"
source "$REPO_ROOT/.mise/lib/common.sh"
source "$REPO_ROOT/.mise/lib/inventory.sh"
source "$REPO_ROOT/.mise/lib/nix.sh"
load_nix_environment
configure_github_access_token

hosts_checked=0
failed_hosts=()
while IFS= read -r host; do
  [ -n "$host" ] || continue
  hosts_checked=$((hosts_checked + 1))
  log_info "Evaluating $host"
  if evaluate_host "$REPO_ROOT" "$host" false; then
    log_info "$host evaluated successfully"
  else
    log_error "$host evaluation failed"
    failed_hosts+=("$host")
  fi
done < <(inventory_hosts "$REPO_ROOT")

[ "$hosts_checked" -gt 0 ] || die "inventory.toml defines no hosts"
if [ "${#failed_hosts[@]}" -gt 0 ]; then
  log_error "host validation failed: ${failed_hosts[*]}"
  exit 1
fi
log_info "All $hosts_checked configured hosts evaluated successfully"
