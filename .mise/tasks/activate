#!/usr/bin/env bash
# [MISE] description="Deprecated: forward to apply"
# [MISE] hide=true
#
#USAGE arg "[hostname]" help="Inventory host to apply"
#USAGE flag "-d --debug" help="Show verbose Nix output and traces"

set -euo pipefail
args=()
[ -z "${usage_hostname:-}" ] || args+=(--host "${usage_hostname}")
[ "${usage_debug:-false}" != true ] || args+=(--debug)
exec mise run apply -- "${args[@]}"
