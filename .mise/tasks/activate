#!/usr/bin/env bash
# [MISE] description="Activate host config (evaluate-only in CI)"
# [MISE] hide=true
# [MISE] quiet=true
# [MISE] depends=["install-nix"]
#
#USAGE arg "[hostname]" help="Hostname to activate"

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Prefer explicit GITHUB_TOKEN, fall back to gh CLI auth if available
if [ -z "${GITHUB_TOKEN:-}" ]; then
  if gh_token="$(mise x gh -- gh auth token 2>/dev/null)"; then
    export GITHUB_TOKEN="$gh_token"
  fi
fi

if [ -n "${GITHUB_TOKEN:-}" ]; then
  export NIX_CONFIG="${NIX_CONFIG:-}"$'
'"access-tokens = github.com=${GITHUB_TOKEN}"
fi

set +u
source /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh
set -u

# Restart the daemon so it picks up trusted-users from nix.conf
# (the installer may have spawned it before the config was finalized)
if [ "$(uname -s)" = "Linux" ]; then
  sudo systemctl restart nix-daemon
fi

NIX_FLAGS=(--accept-flake-config --extra-experimental-features "nix-command flakes")
HOSTNAME="${usage_hostname:-$(hostname -s)}"
if [ "$(uname -s)" = "Darwin" ]; then
  TARGET=("$REPO_ROOT#darwinConfigurations.${HOSTNAME}.system")
else
  TARGET=("$REPO_ROOT#systemConfigs.${HOSTNAME}")
  HOME_TARGET=("$REPO_ROOT#homeConfigurations.${HOSTNAME}.activationPackage")
fi

echo "==> $( [ "${CI:-false}" = "true" ] && echo "Validating" || echo "Deploying" ) configuration for '${HOSTNAME}'..."
if [[ "${CI:-false}" = "true" ]]; then
  # CI validation-only path: evaluate the derivation without building/activating.
  test "$(nix eval "${NIX_FLAGS[@]}" --raw "${TARGET[0]}.type")" = "derivation"
  if [ -n "${HOME_TARGET:-}" ]; then
    test "$(nix eval "${NIX_FLAGS[@]}" --raw "${HOME_TARGET[0]}.type")" = "derivation"
  fi
  echo "CI detected: Evaluation successful. Skipping build and activation steps."
  exit 0
fi

if [ "$(uname -s)" = "Darwin" ]; then
  # Ensure nix.conf exists so the daemon knows who is trusted and which
  # substituters to use.  A previous activate run (or manual intervention)
  # may have moved it aside.  Restore it temporarily for the build step;
  # we'll move everything aside again before darwin-rebuild takes ownership.
  if [ ! -f /etc/nix/nix.conf ] && [ -f /etc/nix/nix.conf.before-nix-darwin ]; then
    echo "==> Restoring /etc/nix/nix.conf for build step..."
    sudo cp /etc/nix/nix.conf.before-nix-darwin /etc/nix/nix.conf
    sudo launchctl kickstart -k system/org.nixos.nix-daemon
    sleep 2
  fi

  nix build "${NIX_FLAGS[@]}" --out-link "$REPO_ROOT/result" "${TARGET[@]}"

  # nix-darwin refuses to activate if /etc/nix/ contains config files it didn't
  # write.  On first run (or after a Lix/Nix re-install), move them aside so
  # nix-darwin can take ownership.  The settings from these files will be
  # managed by nix-darwin's nix.settings going forward.
  for f in /etc/nix/nix.conf; do
    if [ -f "$f" ] && ! grep -qF 'nix-darwin' "$f" 2>/dev/null; then
      echo "==> Moving $f aside for nix-darwin first-run..."
      sudo mv "$f" "$f.before-nix-darwin"
    fi
  done
  # nix.custom.conf is created by nix:trust and is never managed by nix-darwin.
  # Only move it aside on first-run; once nix-darwin owns the system it manages
  # trusted-users and substituters via nix.settings.
  if [ ! -e /run/current-system/darwin-version ] && [ -f /etc/nix/nix.custom.conf ]; then
    echo "==> Moving /etc/nix/nix.custom.conf aside for nix-darwin first-run..."
    sudo mv /etc/nix/nix.custom.conf /etc/nix/nix.custom.conf.before-nix-darwin
  fi

  echo "==> Activating configuration..."
  sudo "$REPO_ROOT/result/sw/bin/darwin-rebuild" switch --flake "$REPO_ROOT#${HOSTNAME}"
else
  echo "==> Activating system configuration..."
  nix build "${NIX_FLAGS[@]}" --out-link "$REPO_ROOT/result" "$REPO_ROOT#system-manager"
  "$REPO_ROOT/result/bin/system-manager" switch --flake "$REPO_ROOT#${HOSTNAME}" --sudo

  echo "==> Activating home-manager configuration..."
  nix build "${NIX_FLAGS[@]}" "${HOME_TARGET[@]}" --out-link "$REPO_ROOT/.hm-result"
  ACTIVATE_USER="${HOME_MANAGER_USER:-${USER:-$(whoami)}}"
  ACTIVATE_HOME="$(getent passwd "$ACTIVATE_USER" | cut -d: -f6)"
  ACTIVATE_PATH="/nix/var/nix/profiles/default/bin:/run/current-system/sw/bin:$PATH"
  if [ -z "$ACTIVATE_HOME" ]; then
    ACTIVATE_HOME="/home/$ACTIVATE_USER"
  fi
  sudo install -d -m755 -o "$ACTIVATE_USER" -g "$(id -gn "$ACTIVATE_USER")" "/nix/var/nix/profiles/per-user/$ACTIVATE_USER"
  if [ "$(id -un)" = "$ACTIVATE_USER" ]; then
    USER="$ACTIVATE_USER" HOME="$ACTIVATE_HOME" PATH="$ACTIVATE_PATH" HOME_MANAGER_BACKUP_EXT=hm_bak "$REPO_ROOT/.hm-result/activate"
  else
    sudo -u "$ACTIVATE_USER" env USER="$ACTIVATE_USER" HOME="$ACTIVATE_HOME" PATH="$ACTIVATE_PATH" HOME_MANAGER_BACKUP_EXT=hm_bak "$REPO_ROOT/.hm-result/activate"
  fi
fi

# Suggest pushing the host branch to origin after a successful activation.
if [[ "${CI:-false}" != "true" ]]; then
  BRANCH="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
  if [[ "$BRANCH" == host/* ]] && ! git rev-parse --verify "origin/${BRANCH}" &>/dev/null; then
    echo ""
    echo "==> Activation successful! To push this host branch to origin, run:"
    echo "    git push -u origin ${BRANCH}"
  fi
fi
