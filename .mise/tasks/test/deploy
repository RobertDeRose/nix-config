#!/usr/bin/env bash
# [MISE] description="Run Apple Container remote deployment validation"
# [MISE] quiet=true

set -euo pipefail

TASK_FILE="${BASH_SOURCE[0]}"
REPO_ROOT="$(git -C "$(dirname "$TASK_FILE")" rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# shellcheck source=.mise/lib/apple-container.sh
source "$REPO_ROOT/.mise/lib/apple-container.sh"

NAME="apple-ssh-test"
install_apple_container_test_signal_handlers "$NAME"
IMAGE="local/maison-test-linux:24.04"
TARGET="tester"
SSH_KEY="$HOME/.ssh/id_ed25519"
PUBKEY_FILE="$HOME/.ssh/id_ed25519.pub"
PUBKEY_DIR="$(dirname "$PUBKEY_FILE")"
PUBKEY_NAME="$(basename "$PUBKEY_FILE")"
KNOWN_HOSTS="$HOME/.ssh/known_hosts"
STAGE_DIR="$(mktemp -d "${TMPDIR:-/tmp}/maison-deploy.XXXXXX")"
SSH_OPTIONS=(
  -i "$SSH_KEY"
  -o IdentitiesOnly=yes
  -o StrictHostKeyChecking=no
  -o UserKnownHostsFile=/dev/null
  -o LogLevel=ERROR
)

github_token="${GITHUB_TOKEN:-}"
if [ -z "$github_token" ] && command -v gh > /dev/null 2>&1; then
  github_token="$(gh auth token 2> /dev/null || true)"
fi
if [ -z "$github_token" ]; then
  cat >&2 << 'EOF'
ERROR: test:deploy requires GitHub authentication.

Set GITHUB_TOKEN in the environment or authenticate the GitHub CLI:

  gh auth login

The resolved token is passed to the remote mise installation so GitHub-backed
tools use the authenticated API rate limit.
EOF
  exit 1
fi
export GITHUB_TOKEN="$github_token"

cleanup() {
  rm -rf "$STAGE_DIR"
}
trap cleanup EXIT

if [ ! -f "$SSH_KEY" ] || [ ! -f "$PUBKEY_FILE" ]; then
  echo "ERROR: SSH keypair not found at $SSH_KEY / $PUBKEY_FILE"
  exit 1
fi

if ! apple_container_exists "$NAME"; then
  echo "==> No reusable Apple container '$NAME' exists; building the Linux test image..."
  mise run test:image
fi

echo "==> Preparing deterministic staged repo copy for deploy test..."
rsync -a --delete \
  --exclude .git \
  --exclude .build \
  --exclude result \
  --exclude .hm-result \
  "$REPO_ROOT/" "$STAGE_DIR/"
git -C "$STAGE_DIR" init -q
git -C "$STAGE_DIR" config user.name "Maison Deploy Test"
git -C "$STAGE_DIR" config user.email "maison-deploy-test@localhost"
cat >> "$STAGE_DIR/inventory.toml" << 'EOF'

[users.tester]
username = "tester"
full_name = "Container Test User"
email = "tester@localhost"
github = "RobertDeRose"

[hosts.apple-ssh-test]
system = "aarch64-linux"
user = "tester"
profiles = ["base", "linux"]
EOF
mise trust "$STAGE_DIR/mise.toml" > /dev/null
(
  cd "$STAGE_DIR"
  mise run host:validate
)
git -C "$STAGE_DIR" add -A
env \
  GIT_AUTHOR_DATE=2000-01-01T00:00:00Z \
  GIT_COMMITTER_DATE=2000-01-01T00:00:00Z \
  git -C "$STAGE_DIR" commit -qm 'test: stage deploy fixture'

ensure_apple_test_container "$NAME" \
  --cap-add ALL \
  --tmpfs /run \
  --tmpfs /tmp \
  --dns 1.1.1.1 \
  --dns 8.8.8.8 \
  -v "$PUBKEY_DIR:/workspace/host-ssh" \
  "$IMAGE" \
  /lib/systemd/systemd --system

echo "==> Waiting for Apple container '$NAME' to become ready..."
wait_for_apple_container "$NAME"
IP="$(apple_container_ipv4 "$NAME")"

echo "==> Installing SSH key for $TARGET@$IP..."
container exec "$NAME" sh -lc "cp /workspace/host-ssh/$PUBKEY_NAME /home/tester/.ssh/authorized_keys && chown tester:tester /home/tester/.ssh/authorized_keys && chmod 600 /home/tester/.ssh/authorized_keys"

echo "==> Waiting for SSH to accept connections..."
SSH_READY=false
for _ in $(seq 1 120); do
  if ssh -T "${SSH_OPTIONS[@]}" -o ConnectTimeout=2 "$TARGET@$IP" true > /dev/null 2>&1; then
    SSH_READY=true
    break
  fi
  sleep 1
done

if [ "$SSH_READY" != true ]; then
  echo "ERROR: SSH on $TARGET@$IP did not become ready in time."
  exit 1
fi

if ssh -T "${SSH_OPTIONS[@]}" "$TARGET@$IP" /bin/bash -s << 'EOF'; then
test -x /home/linuxbrew/.linuxbrew/bin/brew &&
  test -x "$HOME/.local/bin/mise" &&
  test -x /nix/var/nix/profiles/default/bin/nix
EOF
  echo "==> Reusing bootstrap prerequisites from existing deploy test container..."
else
  echo "==> Installing bootstrap prerequisites on remote test target..."
  remote_bootstrap_token_file="$(ssh -T "${SSH_OPTIONS[@]}" "$TARGET@$IP" 'umask 077; mktemp /tmp/maison-bootstrap-token.XXXXXX')"
  # remote_bootstrap_token_file is intentionally expanded locally from a remote mktemp result.
  # shellcheck disable=SC2029
  printf '%s' "$GITHUB_TOKEN" | ssh -T "${SSH_OPTIONS[@]}" "$TARGET@$IP" "cat > '$remote_bootstrap_token_file'"
  ssh -T "${SSH_OPTIONS[@]}" "$TARGET@$IP" /bin/bash -s -- "$remote_bootstrap_token_file" << 'EOF'
set -euo pipefail
unset LC_ALL
export LANG=C.UTF-8
export LC_CTYPE=C.UTF-8
github_token_file="$1"
github_token="$(cat "$github_token_file")"
rm -f "$github_token_file"

# Bootstrap order is part of the deployment contract: Homebrew, mise, Nix/Lix.
if [ ! -x /home/linuxbrew/.linuxbrew/bin/brew ]; then
  HOMEBREW_GITHUB_API_TOKEN="$github_token" NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi
if [ ! -x "$HOME/.local/bin/mise" ]; then
  curl -sSfL https://mise.run | sh
fi
if [ ! -x /nix/var/nix/profiles/default/bin/nix ]; then
  export NIX_INSTALLER_NO_CONFIRM=true
  export NIX_INSTALLER_ENABLE_FLAKES=true
  curl -sSfL https://install.lix.systems/lix | sh -s -- install
fi
EOF
fi

echo "==> Configuring trusted-users and PATH on remote target..."
ssh -T "${SSH_OPTIONS[@]}" "$TARGET@$IP" /bin/bash -s << 'EOF'
sudo sh -lc '
mkdir -p /etc/nix /usr/local/bin
touch /etc/nix/nix.custom.conf
if ! grep -qE "^(extra-)?trusted-users\\b.*\\btester\\b" /etc/nix/nix.conf /etc/nix/nix.custom.conf 2>/dev/null; then
  if grep -q "^extra-trusted-users" /etc/nix/nix.custom.conf; then
    sed -i "s/^extra-trusted-users.*/& tester/" /etc/nix/nix.custom.conf
  else
    printf "extra-trusted-users = tester\\n" >> /etc/nix/nix.custom.conf
  fi
fi
ln -sf /nix/var/nix/profiles/default/bin/nix-store /usr/local/bin/nix-store
ln -sf /nix/var/nix/profiles/default/bin/nix /usr/local/bin/nix
systemctl restart nix-daemon.socket 2>/dev/null || true
systemctl restart nix-daemon.service 2>/dev/null || true
'
EOF

echo "==> Trusting remote host key in local known_hosts..."
touch "$KNOWN_HOSTS"
ssh-keygen -R "$IP" -f "$KNOWN_HOSTS" > /dev/null 2>&1 || true
ssh-keyscan "$IP" >> "$KNOWN_HOSTS"

run_deploy_test() {
  cd "$STAGE_DIR"
  GIT_SSH_COMMAND="ssh -i '$SSH_KEY' -o IdentitiesOnly=yes" \
    mise run deploy -- "$TARGET@$IP" apple-ssh-test
}

echo "==> Running deployment test..."
run_apple_container_test_command run_deploy_test

echo "==> Verifying remote mise installation and global tools..."
ssh -T "${SSH_OPTIONS[@]}" "$TARGET@$IP" /bin/bash -s << 'EOF'
set -euo pipefail
test -x "$HOME/.local/bin/mise"
test -x "$HOME/.local/bin/maison"
test -f "$HOME/.maison/mise.toml"
test -f "$HOME/.maison/flake.nix"
MISE_CONFIG_FILE="$HOME/.config/mise/config.toml" "$HOME/.local/bin/mise" --version
MISE_CONFIG_FILE="$HOME/.config/mise/config.toml" "$HOME/.local/bin/mise" exec -- wt --version
test -x /home/linuxbrew/.linuxbrew/bin/brew
/home/linuxbrew/.linuxbrew/bin/brew --version
test "$(locale charmap)" = "UTF-8"
test "$LANG" = "C.UTF-8"
test "$LC_CTYPE" = "C.UTF-8"
# The login-shell probe intentionally expands locale variables remotely.
# shellcheck disable=SC2016
zsh -lc 'test "$LANG" = C.UTF-8 && test "$LC_CTYPE" = C.UTF-8 && [[ -o multibyte ]]'
"$HOME/.local/bin/maison" --help > /dev/null
command -v maison
EOF

echo ""
echo "Deploy test completed against $TARGET@$IP using container '$NAME'."
