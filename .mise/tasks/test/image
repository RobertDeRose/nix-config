#!/usr/bin/env bash
# [MISE] description="Build the Apple Container Linux test image"
# [MISE] hide=true
# [MISE] quiet=true

set -euo pipefail

TASK_FILE="${BASH_SOURCE[0]}"
REPO_ROOT="$(git -C "$(dirname "$TASK_FILE")" rev-parse --show-toplevel)"
cd "$REPO_ROOT"

IMAGE="local/nix-config-test-linux:24.04"

echo "==> Building Linux test image $IMAGE..."
container build -f test/Containerfile -t "$IMAGE" .
