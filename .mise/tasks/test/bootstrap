#!/usr/bin/env bash
# [MISE] description="Run Linux bootstrap validation in an Apple container"
# [MISE] quiet=true
#
#USAGE arg "[hostname]" help="Test hostname passed to bootstrap" default="ci-bootstrap"
#USAGE flag "--dev" help="Include the Linux developer profile"

set -euo pipefail

TASK_FILE="${BASH_SOURCE[0]}"
REPO_ROOT="$(git -C "$(dirname "$TASK_FILE")" rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# shellcheck source=.mise/lib/apple-container.sh
source "$REPO_ROOT/.mise/lib/apple-container.sh"

NAME="test-bootstrap"
install_apple_container_test_signal_handlers "$NAME"

cleanup() {
  stop_and_delete_apple_test_container "$NAME"
}
trap cleanup EXIT

HOSTNAME="${usage_hostname:-ci-bootstrap}"
PROFILES="base,linux"
if [ "${usage_dev:-false}" = true ]; then
  PROFILES="base,dev,linux"
fi
IMAGE="local/maison-test-linux:24.04"
BRANCH="$(git branch --show-current)"
ORIGIN_URL="$(git remote get-url origin)"

github_token="${GITHUB_TOKEN:-}"
if [ -z "$github_token" ] && command -v gh > /dev/null 2>&1; then
  github_token="$(gh auth token 2> /dev/null || true)"
fi

if [ -z "$github_token" ]; then
  cat >&2 << 'EOF'
ERROR: test:bootstrap requires GitHub authentication.

Set GITHUB_TOKEN in the environment or authenticate the GitHub CLI:

  gh auth login

The resolved token is passed into the test container as GITHUB_TOKEN so mise
and other GitHub API clients use the authenticated rate limit.
EOF
  exit 1
fi

run_apple_container_test_command mise run test:image

if [ -z "$BRANCH" ]; then
  echo "ERROR: test:bootstrap must be run from a named branch."
  exit 1
fi

# Validate branch name doesn't contain URL-breaking characters.
# Note: '/' in branch names is fine — GitHub raw URLs resolve them correctly.
if [[ $BRANCH =~ [[:space:]\?\#] ]]; then
  echo "ERROR: Branch name '$BRANCH' contains characters that break URL construction."
  exit 1
fi

case "$ORIGIN_URL" in
  git@github.com:*.git)
    REPO="${ORIGIN_URL#git@github.com:}"
    REPO="${REPO%.git}"
    ;;
  https://github.com/*.git)
    REPO="${ORIGIN_URL#https://github.com/}"
    REPO="${REPO%.git}"
    ;;
  https://github.com/*)
    REPO="${ORIGIN_URL#https://github.com/}"
    ;;
  *)
    echo "ERROR: Unsupported origin URL: $ORIGIN_URL"
    exit 1
    ;;
esac

if ! git rev-parse --verify --quiet "origin/$BRANCH" > /dev/null; then
  echo "WARNING: origin/$BRANCH does not exist yet, so test:bootstrap cannot exercise this branch."
  echo "         Push this branch first, then rerun test:bootstrap."
  exit 1
fi

if ! git diff --quiet || ! git diff --cached --quiet; then
  echo "WARNING: Local changes are not pushed to origin and will not be tested by test:bootstrap."
fi

if git rev-parse --verify --quiet "origin/$BRANCH" > /dev/null && [ "$(git rev-list --count "origin/$BRANCH..HEAD")" -gt 0 ]; then
  echo "WARNING: This branch has local commits not pushed to origin/$BRANCH; they will not be tested."
fi

BOOTSTRAP_URL="https://raw.githubusercontent.com/$REPO/$BRANCH/bootstrap.sh"

echo "==> Recreating Apple container '$NAME'..."
container delete --force "$NAME" > /dev/null 2>&1 || true
container run -d \
  --name "$NAME" \
  --memory 4G \
  --cap-add ALL \
  --tmpfs /run \
  --tmpfs /tmp \
  --dns 1.1.1.1 \
  --dns 8.8.8.8 \
  "$IMAGE" \
  /lib/systemd/systemd --system > /dev/null

echo "==> Waiting for Apple container '$NAME' to become ready..."
wait_for_apple_container "$NAME"

echo "==> Running bootstrap validation from $BOOTSTRAP_URL..."
printf -v bootstrap_command \
  'git config --global user.name %q && git config --global user.email %q && curl -sSfL %q | bash -s -- --host %q --repo %q --ref %q --profiles %q' \
  'Container Test User' \
  'tester@localhost' \
  "$BOOTSTRAP_URL" \
  "$HOSTNAME" \
  "$REPO" \
  "$BRANCH" \
  "$PROFILES"

run_apple_container_test_command \
  container exec "$NAME" \
  sudo -iu tester \
  env \
  GITHUB_TOKEN="$github_token" \
  HOME_MANAGER_USER=tester \
  NIX_BUILD_CORES=1 \
  CARGO_BUILD_JOBS=1 \
  NIX_INSTALLER_NO_SANDBOX=true \
  bash -lc "$bootstrap_command"

# The login-shell probe intentionally expands locale variables inside the container.
# shellcheck disable=SC2016
container exec "$NAME" sudo -iu tester zsh -lc \
  'test "$(locale charmap)" = UTF-8 && test "$LANG" = C.UTF-8 && test "$LC_CTYPE" = C.UTF-8 && [[ -o multibyte ]]'

echo ""
echo "Bootstrap test completed in container '$NAME'."
