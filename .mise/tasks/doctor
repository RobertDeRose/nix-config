#!/usr/bin/env bash
# [MISE] description="Diagnose repository and machine prerequisites without making changes"
#
#USAGE flag "--json" help="Emit machine-readable JSON"
#USAGE flag "--host <host>" help="Host to diagnose (defaults to the current hostname)"

set -euo pipefail

TASK_FILE="${BASH_SOURCE[0]}"
REPO_ROOT="$(git -C "$(dirname "$TASK_FILE")" rev-parse --show-toplevel)"
cd "$REPO_ROOT"
source "$REPO_ROOT/.mise/lib/common.sh"
source "$REPO_ROOT/.mise/lib/platform.sh"
source "$REPO_ROOT/.mise/lib/inventory.sh"
source "$REPO_ROOT/.mise/lib/git.sh"

host="${usage_host:-$(current_hostname)}"
json="${usage_json:-false}"
errors=0
warnings=0
results=""

record() {
  local level="$1" name="$2" message="$3"
  case "$level" in error) errors=$((errors + 1));; warning) warnings=$((warnings + 1));; esac
  if [ "$json" = true ]; then
    [ -z "$results" ] || results="$results,"
    results="$results{\"status\":\"$(json_escape "$level")\",\"check\":\"$(json_escape "$name")\",\"message\":\"$(json_escape "$message")\"}"
  else
    printf '%-7s %-22s %s\n' "[$level]" "$name" "$message"
  fi
}

[ -d "$REPO_ROOT/.git" ] && record ok repository "$REPO_ROOT" || record error repository "not inside the repository"
if command -v mise >/dev/null 2>&1; then record ok mise "$(mise --version 2>/dev/null | head -n1)"; else record error mise "command not found"; fi
if command -v nix >/dev/null 2>&1 || [ -x /nix/var/nix/profiles/default/bin/nix ]; then record ok nix "Nix/Lix is installed"; else record error nix "Nix/Lix is not installed"; fi
if [ "$(current_os)" = linux ]; then
  [ -S /nix/var/nix/daemon-socket/socket ] && record ok nix-daemon "daemon socket is available" || record error nix-daemon "daemon socket is unavailable"
else
  pgrep -q nix-daemon 2>/dev/null && record ok nix-daemon "daemon is running" || record warning nix-daemon "daemon process was not detected"
fi
if inventory_has_host "$REPO_ROOT" "$host"; then
  record ok host "$host is defined as $(inventory_host_system "$REPO_ROOT" "$host")"
  if validate_host_platform "$REPO_ROOT" "$host" "$(current_system)" >/dev/null 2>&1; then record ok platform "$(current_system)"; else record error platform "host and current machine systems differ"; fi
else
  record error host "$host is not defined"
fi
command -v git >/dev/null 2>&1 && record ok git "$(git --version)" || record error git "command not found"
if command -v gh >/dev/null 2>&1 && gh auth status >/dev/null 2>&1; then record ok github "GitHub CLI is authenticated"; else record warning github "GitHub CLI is unavailable or unauthenticated"; fi
if [ "$(current_os)" = darwin ]; then
  command -v brew >/dev/null 2>&1 && record ok homebrew "Homebrew is installed" || record error homebrew "Homebrew is not installed"
fi
if grep -Rqs 'robertderose.cachix.org' modules nix 2>/dev/null; then record ok personal-cache "configured as optional acceleration"; else record warning personal-cache "not configured; correctness must not depend on it"; fi
bad_modes="$(find .mise/tasks -type f ! -perm -u+x -print)"
[ -z "$bad_modes" ] && record ok task-modes "all file tasks are executable" || record error task-modes "non-executable tasks: $(printf '%s' "$bad_modes" | tr '\n' ' ')"
bad_headers="$(find .mise/tasks -type f -exec awk 'FNR==1 && $0!="#!/usr/bin/env bash" {print FILENAME}' {} +)"
[ -z "$bad_headers" ] && record ok task-metadata "task headers are present" || record error task-metadata "invalid task headers detected"
if git_is_dirty "$REPO_ROOT" 2>/dev/null; then record warning working-tree "uncommitted changes are present"; else record ok working-tree "clean"; fi
[ ! -e "$HOME/.gitconfig" ] && record ok link-conflicts "no legacy ~/.gitconfig" || record warning link-conflicts "~/.gitconfig may hide the managed XDG Git config"

if [ "$json" = true ]; then
  printf '{"errors":%d,"warnings":%d,"checks":[%s]}\n' "$errors" "$warnings" "$results"
else
  printf '\nErrors: %d  Warnings: %d\n' "$errors" "$warnings"
fi
[ "$errors" -eq 0 ]
