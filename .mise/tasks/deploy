#!/usr/bin/env bash
# [MISE] description="Build locally and deploy a Linux host over SSH"
# [MISE] interactive=true
#
#USAGE arg "<destination>" help="SSH destination such as user@host or an SSH config alias"
#USAGE arg "[host]" help="Inventory host name (defaults to the remote hostname)"
#USAGE flag "-d --debug" help="Show verbose Nix output and traces"

# usage_* variables are injected by mise's file-task argument parser.
# shellcheck disable=SC2154

set -euo pipefail

TASK_FILE="${BASH_SOURCE[0]}"
REPO_ROOT="$(git -C "$(dirname "$TASK_FILE")" rev-parse --show-toplevel)"
cd "$REPO_ROOT"
source "$REPO_ROOT/.mise/lib/common.sh"
source "$REPO_ROOT/.mise/lib/platform.sh"
source "$REPO_ROOT/.mise/lib/inventory.sh"
source "$REPO_ROOT/.mise/lib/nix.sh"

destination="${usage_destination}"
host="${usage_host:-}"
debug="${usage_debug:-false}"
if [ -z "$host" ]; then
  host="$(ssh -T "$destination" hostname -s)"
  log_info "Detected remote hostname: $host"
fi
validate_hostname "$host" || die "invalid host name '$host'"
require_inventory_host "$REPO_ROOT" "$host"
system="$(inventory_host_system "$REPO_ROOT" "$host")"
case "$system" in *-linux) ;; *) die "deploy supports Linux hosts only; '$host' is $system" ;; esac

inventory_user="$(inventory_host_user "$REPO_ROOT" "$host")"
managed_user="$(require_inventory_user_for_host "$REPO_ROOT" "$host")"
github_user="$(inventory_user_field "$REPO_ROOT" "$inventory_user" github)"
validate_github_username "$github_user" || die "invalid GitHub username '$github_user' for user '$inventory_user'"

load_nix_environment
configure_github_access_token
[ -n "${GITHUB_TOKEN:-}" ] || die "GitHub authentication is required for remote mise installation; set GITHUB_TOKEN or run gh auth login"
log_info "Building all deployment outputs before modifying the remote host"
build_host "$REPO_ROOT" "$host" "$debug"

log_info "Checking published GitHub SSH keys for $github_user"
keys="$(curl -fsSL --connect-timeout 5 --max-time 10 "https://github.com/$github_user.keys")" || die "failed to fetch GitHub SSH keys for '$github_user'"
[ -n "$keys" ] || die "GitHub user '$github_user' has no published SSH keys"

if ! ssh -T -o BatchMode=yes -o ConnectTimeout=5 "$destination" true 2> /dev/null; then
  require_command ssh-copy-id
  ssh-copy-id "$destination"
fi

if ! ssh -T "$destination" 'command -v nix >/dev/null 2>&1 && command -v nix-store >/dev/null 2>&1'; then
  die "remote host '$destination' is not bootstrapped: Nix/Lix is unavailable; run bootstrap first"
fi

if ! ssh -T "$destination" sh -s -- "$managed_user" << 'REMOTE_MISE_CHECK'; then
set -eu
managed_user="$1"
managed_home="$(getent passwd "$managed_user" | cut -d: -f6)"
[ -n "$managed_home" ] || managed_home="/home/$managed_user"
test -x "$managed_home/.local/bin/mise"
REMOTE_MISE_CHECK
  die "remote host '$destination' is not bootstrapped: mise is unavailable for '$managed_user'; run bootstrap first"
fi

if ! ssh -T "$destination" 'test -x /home/linuxbrew/.linuxbrew/bin/brew'; then
  die "remote host '$destination' is not bootstrapped: Homebrew for Linux is unavailable; run bootstrap first"
fi

ssh_user="$(ssh -G "$destination" | sed -n 's/^user //p' | head -n1)"
[ -n "$ssh_user" ] || ssh_user="$(printf '%s' "$destination" | sed -n 's/@.*//p')"
log_info "Ensuring remote Nix trusts SSH user ${ssh_user:-unknown}"
ssh_tty=(-T)
if [ -t 0 ] && [ -t 1 ]; then
  ssh_tty=(-t)
fi
ssh "${ssh_tty[@]}" "$destination" 'bash -s' << 'REMOTE_TRUST'
set -euo pipefail
trusted_user="$(id -un)"
conf=/etc/nix/nix.conf
run_root() { if [ "$(id -u)" -eq 0 ]; then "$@"; else sudo "$@"; fi; }
if [ "$(id -u)" -ne 0 ]; then
  command -v sudo >/dev/null 2>&1 || { echo "remote trust setup requires root or sudo" >&2; exit 1; }
  sudo -v
fi
run_root mkdir -p /etc/nix
run_root touch "$conf"
if ! grep -qE "^(extra-)?trusted-users[[:space:]]*=.*(^|[[:space:]])${trusted_user}([[:space:]]|$)" "$conf" 2>/dev/null; then
  printf 'extra-trusted-users = %s\n' "$trusted_user" | run_root tee -a "$conf" >/dev/null
fi
run_root systemctl restart nix-daemon.socket 2>/dev/null || true
run_root systemctl restart nix-daemon.service 2>/dev/null || true
REMOTE_TRUST

system_ref="$(linux_system_target_for_host "$REPO_ROOT" "$host")"
home_ref="$(linux_home_target_for_host "$REPO_ROOT" "$host")"
manager_args=(
  --target-host "$destination"
  --nix-option accept-flake-config true
  switch
  --flake "$system_ref"
)
if [ "$ssh_user" != root ]; then manager_args+=(--sudo); fi
log_info "Activating system configuration for $host"
"$REPO_ROOT/.build/system-manager/bin/system-manager" "${manager_args[@]}"

home_store_path="$(nix_command "$debug" path-info "$home_ref")"
log_info "Copying Home Manager activation closure"
nix_command "$debug" copy --to "ssh://$destination" "$home_store_path"
log_info "Activating Home Manager for $managed_user"
remote_token_file="$(ssh -T "$destination" 'umask 077; mktemp /tmp/maison-github-token.XXXXXX')"
# remote_token_file is intentionally expanded locally from a remote mktemp result.
# shellcheck disable=SC2029
printf '%s' "$GITHUB_TOKEN" | ssh -T "$destination" "cat > '$remote_token_file'"
ssh -T "$destination" sh -s -- "$managed_user" "$home_store_path/activate" "$remote_token_file" << 'REMOTE_HOME'
set -eu
activate_user="$1"
hm_activate="$2"
github_token_file="$3"
github_token="$(cat "$github_token_file")"
rm -f "$github_token_file"
[ -n "$github_token" ] || { echo "GitHub token is unavailable for remote mise installation" >&2; exit 1; }
current_user="$(id -un)"
activate_home="$(getent passwd "$activate_user" | cut -d: -f6)"
[ -n "$activate_home" ] || activate_home="/home/$activate_user"
activate_path="/nix/var/nix/profiles/default/bin:/run/current-system/sw/bin:$PATH"
if [ "$current_user" = root ]; then
  install -d -m755 -o "$activate_user" -g "$(id -gn "$activate_user")" "/nix/var/nix/profiles/per-user/$activate_user"
elif [ "$current_user" != "$activate_user" ]; then
  sudo install -d -m755 -o "$activate_user" -g "$(id -gn "$activate_user")" "/nix/var/nix/profiles/per-user/$activate_user"
fi
if [ "$current_user" = "$activate_user" ]; then
  env USER="$activate_user" HOME="$activate_home" PATH="$activate_path" HOME_MANAGER_BACKUP_EXT=hm_bak "$hm_activate"
elif [ "$current_user" = root ] && command -v runuser >/dev/null 2>&1; then
  runuser -u "$activate_user" -- env USER="$activate_user" HOME="$activate_home" PATH="$activate_path" HOME_MANAGER_BACKUP_EXT=hm_bak "$hm_activate"
elif [ "$current_user" = root ]; then
  su -s /bin/sh "$activate_user" -c "USER='$activate_user' HOME='$activate_home' PATH='$activate_path' HOME_MANAGER_BACKUP_EXT=hm_bak '$hm_activate'"
else
  sudo -u "$activate_user" env USER="$activate_user" HOME="$activate_home" PATH="$activate_path" HOME_MANAGER_BACKUP_EXT=hm_bak "$hm_activate"
fi

mise_bin="$activate_home/.local/bin/mise"
mise_config="$activate_home/.config/mise/config.toml"
[ -x "$mise_bin" ] || { echo "mise is unavailable for $activate_user; run bootstrap first" >&2; exit 1; }
[ -f "$mise_config" ] || { echo "Home Manager did not create the global mise config: $mise_config" >&2; exit 1; }

run_mise_install_once() {
  if [ "$current_user" = "$activate_user" ]; then
    env USER="$activate_user" HOME="$activate_home" PATH="$activate_home/.local/bin:$activate_path" MISE_CONFIG_FILE="$mise_config" GITHUB_TOKEN="$github_token" "$mise_bin" install
  elif [ "$current_user" = root ] && command -v runuser >/dev/null 2>&1; then
    runuser -u "$activate_user" -- env USER="$activate_user" HOME="$activate_home" PATH="$activate_home/.local/bin:$activate_path" MISE_CONFIG_FILE="$mise_config" GITHUB_TOKEN="$github_token" "$mise_bin" install
  elif [ "$current_user" = root ]; then
    GITHUB_TOKEN="$github_token" su -m -s /bin/sh "$activate_user" -c "USER='$activate_user' HOME='$activate_home' PATH='$activate_home/.local/bin:$activate_path' MISE_CONFIG_FILE='$mise_config' '$mise_bin' install"
  else
    sudo -u "$activate_user" env USER="$activate_user" HOME="$activate_home" PATH="$activate_home/.local/bin:$activate_path" MISE_CONFIG_FILE="$mise_config" GITHUB_TOKEN="$github_token" "$mise_bin" install
  fi
}

retry_mise_install() {
  attempt=1
  max_attempts=4
  while ! run_mise_install_once; do
    if [ "$attempt" -ge "$max_attempts" ]; then
      echo "Global mise tool installation failed after $max_attempts attempts" >&2
      return 1
    fi
    delay=$((attempt * 10))
    echo "Global mise tool installation failed; retrying in ${delay}s ($attempt/$max_attempts)" >&2
    sleep "$delay"
    attempt=$((attempt + 1))
  done
}

retry_mise_install
REMOTE_HOME

log_info "Installing Maison repository and command for $managed_user"
maison_archive="$(mktemp "${TMPDIR:-/tmp}/maison-deploy.XXXXXX.tar.gz")"
remote_maison_archive="$(ssh -T "$destination" 'umask 077; mktemp /tmp/maison-deploy.XXXXXX.tar.gz')"
remote_maison_token_file="$(ssh -T "$destination" 'umask 077; mktemp /tmp/maison-github-token.XXXXXX')"
# remote_maison_token_file is intentionally expanded locally from a remote mktemp result.
# shellcheck disable=SC2029
printf '%s' "$GITHUB_TOKEN" | ssh -T "$destination" "cat > '$remote_maison_token_file'"
cleanup_maison_archive() {
  rm -f "$maison_archive"
  # Remote paths are intentionally expanded locally from remote mktemp results.
  # shellcheck disable=SC2029
  ssh -T "$destination" "rm -f '$remote_maison_archive' '$remote_maison_token_file'" > /dev/null 2>&1 || true
}
trap cleanup_maison_archive EXIT

tar --exclude='./.build' --exclude='./result' --exclude='./.hm-result' --exclude='./.direnv' -czf "$maison_archive" -C "$REPO_ROOT" .
scp -q "$maison_archive" "$destination:$remote_maison_archive"
ssh -T "$destination" sh -s -- "$managed_user" "$remote_maison_archive" "$remote_maison_token_file" << 'REMOTE_MAISON'
set -eu
managed_user="$1"
archive="$2"
github_token_file="$3"
github_token="$(cat "$github_token_file")"
rm -f "$github_token_file"
[ -n "$github_token" ] || { echo "GitHub token is unavailable for Maison project tool installation" >&2; exit 1; }
managed_home="$(getent passwd "$managed_user" | cut -d: -f6)"
[ -n "$managed_home" ] || managed_home="/home/$managed_user"
managed_group="$(id -gn "$managed_user")"
staging="$(mktemp -d /tmp/maison-install.XXXXXX)"
trap 'rm -rf "$staging" "$archive"' EXIT HUP INT TERM
tar -xzf "$archive" -C "$staging"

install_maison() {
  rm -rf "$managed_home/.maison"
  mv "$staging" "$managed_home/.maison"
  mkdir -p "$managed_home/.local/bin"
  ln -sfn "$managed_home/.maison/bin/maison" "$managed_home/.local/bin/maison"
  chown -R "$managed_user:$managed_group" "$managed_home/.maison" "$managed_home/.local/bin/maison"
}

if [ "$(id -u)" -eq 0 ]; then
  install_maison
else
  command -v sudo >/dev/null 2>&1 || { echo "Maison installation requires root or sudo" >&2; exit 1; }
  sudo sh -c "rm -rf '$managed_home/.maison' && mv '$staging' '$managed_home/.maison' && mkdir -p '$managed_home/.local/bin' && ln -sfn '$managed_home/.maison/bin/maison' '$managed_home/.local/bin/maison' && chown -R '$managed_user:$managed_group' '$managed_home/.maison' '$managed_home/.local/bin/maison'"
fi

run_project_mise_install() {
  env USER="$managed_user" HOME="$managed_home" PATH="$managed_home/.local/bin:$PATH" \
    GITHUB_TOKEN="$github_token" MISE_GITHUB_TOKEN="$github_token" \
    HOMEBREW_GITHUB_API_TOKEN="$github_token" \
    "$managed_home/.local/bin/mise" -C "$managed_home/.maison" install
}

retry_project_mise_install() {
  attempt=1
  max_attempts=4
  while ! run_project_mise_install; do
    if [ "$attempt" -ge "$max_attempts" ]; then
      echo "Maison project tool installation failed after $max_attempts attempts" >&2
      return 1
    fi
    delay=$((attempt * 10))
    echo "Maison project tool installation failed; retrying in ${delay}s ($attempt/$max_attempts)" >&2
    sleep "$delay"
    attempt=$((attempt + 1))
  done
}

install_maison_tools() {
  mise_bin="$managed_home/.local/bin/mise"
  [ -x "$mise_bin" ] || { echo "mise is unavailable for $managed_user; run bootstrap first" >&2; exit 1; }
  env USER="$managed_user" HOME="$managed_home" PATH="$managed_home/.local/bin:$PATH" \
    "$mise_bin" trust "$managed_home/.maison/mise.toml"
  retry_project_mise_install
  usage_bin="$(env USER="$managed_user" HOME="$managed_home" PATH="$managed_home/.local/bin:$PATH" "$mise_bin" -C "$managed_home/.maison" which usage)"
  [ -x "$usage_bin" ] || { echo "Usage was not installed with the Maison project tools" >&2; exit 1; }
  ln -sfn "$usage_bin" "$managed_home/.local/bin/usage"
}

if [ "$(id -un)" = "$managed_user" ]; then
  install_maison_tools
elif [ "$(id -u)" -eq 0 ] && command -v runuser >/dev/null 2>&1; then
  runuser -u "$managed_user" -- env USER="$managed_user" HOME="$managed_home" PATH="$managed_home/.local/bin:$PATH" \
    "$managed_home/.local/bin/mise" trust "$managed_home/.maison/mise.toml"
  attempt=1
  max_attempts=4
  until runuser -u "$managed_user" -- env USER="$managed_user" HOME="$managed_home" PATH="$managed_home/.local/bin:$PATH" \
    GITHUB_TOKEN="$github_token" MISE_GITHUB_TOKEN="$github_token" HOMEBREW_GITHUB_API_TOKEN="$github_token" \
    "$managed_home/.local/bin/mise" -C "$managed_home/.maison" install; do
    [ "$attempt" -lt "$max_attempts" ] || { echo "Maison project tool installation failed after $max_attempts attempts" >&2; exit 1; }
    delay=$((attempt * 10))
    echo "Maison project tool installation failed; retrying in ${delay}s ($attempt/$max_attempts)" >&2
    sleep "$delay"
    attempt=$((attempt + 1))
  done
  usage_bin="$(runuser -u "$managed_user" -- env USER="$managed_user" HOME="$managed_home" PATH="$managed_home/.local/bin:$PATH" "$managed_home/.local/bin/mise" -C "$managed_home/.maison" which usage)"
  [ -x "$usage_bin" ] || { echo "Usage was not installed with the Maison project tools" >&2; exit 1; }
  ln -sfn "$usage_bin" "$managed_home/.local/bin/usage"
elif [ "$(id -u)" -eq 0 ]; then
  su -m -s /bin/sh "$managed_user" -c "USER='$managed_user' HOME='$managed_home' PATH='$managed_home/.local/bin:$PATH' '$managed_home/.local/bin/mise' trust '$managed_home/.maison/mise.toml'"
  attempt=1
  max_attempts=4
  until GITHUB_TOKEN="$github_token" MISE_GITHUB_TOKEN="$github_token" HOMEBREW_GITHUB_API_TOKEN="$github_token" \
    su -m -s /bin/sh "$managed_user" -c "USER='$managed_user' HOME='$managed_home' PATH='$managed_home/.local/bin:$PATH' '$managed_home/.local/bin/mise' -C '$managed_home/.maison' install"; do
    [ "$attempt" -lt "$max_attempts" ] || { echo "Maison project tool installation failed after $max_attempts attempts" >&2; exit 1; }
    delay=$((attempt * 10))
    echo "Maison project tool installation failed; retrying in ${delay}s ($attempt/$max_attempts)" >&2
    sleep "$delay"
    attempt=$((attempt + 1))
  done
  usage_bin="$(su -m -s /bin/sh "$managed_user" -c "USER='$managed_user' HOME='$managed_home' PATH='$managed_home/.local/bin:$PATH' '$managed_home/.local/bin/mise' -C '$managed_home/.maison' which usage")"
  [ -x "$usage_bin" ] || { echo "Usage was not installed with the Maison project tools" >&2; exit 1; }
  ln -sfn "$usage_bin" "$managed_home/.local/bin/usage"
else
  sudo -u "$managed_user" env USER="$managed_user" HOME="$managed_home" PATH="$managed_home/.local/bin:$PATH" \
    "$managed_home/.local/bin/mise" trust "$managed_home/.maison/mise.toml"
  attempt=1
  max_attempts=4
  until sudo -u "$managed_user" env USER="$managed_user" HOME="$managed_home" PATH="$managed_home/.local/bin:$PATH" \
    GITHUB_TOKEN="$github_token" MISE_GITHUB_TOKEN="$github_token" HOMEBREW_GITHUB_API_TOKEN="$github_token" \
    "$managed_home/.local/bin/mise" -C "$managed_home/.maison" install; do
    [ "$attempt" -lt "$max_attempts" ] || { echo "Maison project tool installation failed after $max_attempts attempts" >&2; exit 1; }
    delay=$((attempt * 10))
    echo "Maison project tool installation failed; retrying in ${delay}s ($attempt/$max_attempts)" >&2
    sleep "$delay"
    attempt=$((attempt + 1))
  done
  usage_bin="$(sudo -u "$managed_user" env USER="$managed_user" HOME="$managed_home" PATH="$managed_home/.local/bin:$PATH" "$managed_home/.local/bin/mise" -C "$managed_home/.maison" which usage)"
  [ -x "$usage_bin" ] || { echo "Usage was not installed with the Maison project tools" >&2; exit 1; }
  ln -sfn "$usage_bin" "$managed_home/.local/bin/usage"
fi
chown -h "$managed_user:$managed_group" "$managed_home/.local/bin/usage"
REMOTE_MAISON
trap - EXIT
cleanup_maison_archive
