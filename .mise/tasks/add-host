#!/usr/bin/env bash
# [MISE] description="Scaffold a new host from templates, branch, and commit"
# [MISE] hide=true
# [MISE] quiet=true
# [MISE] raw=true
#
#USAGE arg "[hostname]" help="Hostname for the new machine" \
#USAGE   long_help="Used as both the nix config identifier and the machine hostname. Creates a hosts/<arch>-darwin/<hostname>/ or systems/<arch>-linux/<hostname>/ directory from the appropriate template."
#USAGE arg "[os]" help="OS class (default: current machine)" {
#USAGE   choices "darwin" "linux"
#USAGE }
#USAGE arg "[arch]" help="Architecture for the new machine (default: current machine)" long_help="Used to determine the host directory path. Inferred from the current machine if omitted." {
#USAGE   choices "aarch64" "x86_64"
#USAGE }
#USAGE flag "--user <user>" help="Username for the host (default: current user)"
#USAGE flag "--fullname <name>" help="Full name (default: git config user.name)"
#USAGE flag "--email <email>" help="Email (default: git config user.email)"
#USAGE flag "--github <username>" help="GitHub username (default: derived from git remote)"

set -euo pipefail

HOSTNAME="${usage_hostname:-$(hostname -s)}"
OS="${usage_os:-$(uname -s | tr '[A-Z]' '[a-z]')}"
ARCH="${usage_arch:-$(uname -m | sed 's/arm64/aarch64/')}"

if [ "${OS}" != "darwin" ] && [ "${OS}" != "linux" ]; then
  echo "ERROR: invalid os '${OS}'. Expected 'darwin' or 'linux'."
  exit 1
fi

if ! printf '%s' "$HOSTNAME" | grep -Eq '^[A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?$'; then
  echo "ERROR: Invalid hostname '$HOSTNAME'." >&2
  echo "       Use a single DNS label with alphanumeric or hyphen characters." >&2
  exit 1
fi

SYSTEM="${ARCH}-${OS}"
HOST_BRANCH="host/${HOSTNAME}"

# Generate and validate user metadata before writing scaffold files.
USERNAME="${usage_user:-$(whoami)}"
FULLNAME="${usage_fullname:-$(git config user.name 2>/dev/null || echo "")}"
EMAIL="${usage_email:-$(git config user.email 2>/dev/null || echo "")}"
GITHUB="${usage_github:-$(git remote get-url origin 2>/dev/null | sed -n 's|.*github.com[:/]\([^/]*\)/.*|\1|p' || echo "")}"

if [ "$USERNAME" = "root" ]; then
  echo "ERROR: Refusing to scaffold a host with reserved username 'root'." >&2
  echo "       Pass --user <name> or run as the intended managed non-root user." >&2
  exit 1
fi

if ! printf '%s' "$USERNAME" | grep -Eq '^[a-z_][a-z0-9_-]*$'; then
  echo "ERROR: Invalid username '$USERNAME' for host scaffolding." >&2
  echo "       Use --user with a portable POSIX account name." >&2
  exit 1
fi

valid_github_username() {
  printf '%s' "$1" | grep -Eq '^[A-Za-z0-9]([A-Za-z0-9-]{0,37}[A-Za-z0-9])?$'
}

# Prompt for any missing required fields (git may not be configured on a fresh machine)
ask() {
  local prompt="$1" reply
  while true; do
    printf "%s" "$prompt" >&2
    read -r reply < /dev/tty
    if [ -n "$reply" ]; then
      echo "$reply"
      return
    fi
    echo "  This field is required. Please enter a value." >&2
  done
}
if [ -z "$FULLNAME" ]; then
  if [[ "${CI:-false}" == "true" ]]; then
    FULLNAME="CI User"
  else
    FULLNAME="$(ask "Full name: ")"
  fi
fi
if [ -z "$EMAIL" ]; then
  if [[ "${CI:-false}" == "true" ]]; then
    EMAIL="ci@localhost"
  else
    EMAIL="$(ask "Email: ")"
  fi
fi
if [ -z "$GITHUB" ]; then
  if [[ "${CI:-false}" == "true" ]]; then
    GITHUB="ci"
  else
    GITHUB="$(ask "GitHub username: ")"
  fi
fi

if ! valid_github_username "$GITHUB"; then
  echo "ERROR: Invalid GitHub username '$GITHUB' for host scaffolding." >&2
  echo "       GitHub usernames must be 1-39 alphanumeric or hyphen characters and cannot start or end with a hyphen." >&2
  exit 1
fi

# Darwin hosts live under hosts/ (managed by easy-hosts);
# Linux hosts live under systems/ (managed by system-manager).
if [ "${OS}" = "darwin" ]; then
  HOST_DIR="hosts/${SYSTEM}/${HOSTNAME}"
else
  HOST_DIR="systems/${SYSTEM}/${HOSTNAME}"
fi

if [[ "${CI:-false}" != "true" ]]; then
  CURRENT_BRANCH="$(git rev-parse --abbrev-ref HEAD)"
  if [ "$CURRENT_BRANCH" != "$HOST_BRANCH" ]; then
    if ! git diff --quiet || ! git diff --cached --quiet; then
      echo "ERROR: working tree must be clean before switching to ${HOST_BRANCH}."
      echo "Commit or stash your current changes, then rerun add-host."
      exit 1
    fi

    if git rev-parse --verify "$HOST_BRANCH" &>/dev/null; then
      git checkout "$HOST_BRANCH"
    else
      git checkout -b "$HOST_BRANCH"
    fi
  fi
fi

if [ ! -d "${HOST_DIR}" ]; then
  echo "==> Creating ${HOST_DIR} from templates/${OS}..."
  mkdir -p "${HOST_DIR}"
  cp -vr "templates/${OS}"/* "${HOST_DIR}/"
fi

# Escape a value for safe inclusion in a Nix string literal.
# For this use case, escape backslashes, double quotes, and ${ to prevent interpolation.
nix_escape() {
  local val="$1"
  val="${val//\\/\\\\}"      # backslash → \\
  val="${val//\"/\\\"}"      # double quote → \"
  val="${val//\$\{/\\\$\{}"  # ${ → \${  (prevents interpolation)
  printf '%s' "$val"
}

{
  printf '{\n'
  printf '  username = "%s";\n' "$(nix_escape "$USERNAME")"
  printf '  fullname = "%s";\n' "$(nix_escape "$FULLNAME")"
  printf '  useremail = "%s";\n' "$(nix_escape "$EMAIL")"
  printf '  githubUsername = "%s";\n' "$(nix_escape "$GITHUB")"
  printf '}\n'
} > "${HOST_DIR}/user.nix"
echo "    Generated ${HOST_DIR}/user.nix for user '${USERNAME}'"

# Ensure host files are tracked — nix flakes only see git-tracked files.
git add "${HOST_DIR}"

# Commit the new host files so the flake doesn't see a dirty tree.
if [[ "${CI:-false}" != "true" ]] && ! git diff --cached --quiet -- "${HOST_DIR}"; then
  git_commit_args=(-m "feat: add host ${HOSTNAME} (${SYSTEM})" -- "${HOST_DIR}")
  if git config user.name &>/dev/null && git config user.email &>/dev/null; then
    git commit "${git_commit_args[@]}"
  else
    GIT_AUTHOR_NAME="$FULLNAME" \
    GIT_AUTHOR_EMAIL="$EMAIL" \
    GIT_COMMITTER_NAME="$FULLNAME" \
    GIT_COMMITTER_EMAIL="$EMAIL" \
    git commit "${git_commit_args[@]}"
  fi
fi

echo "
Added '${HOSTNAME}' as a ${OS} host in: ${HOST_DIR}

Next steps — apply the configuration with:
  mise run nix:init ${HOSTNAME}
  # or, if Nix is already installed:
  mise run nix:switch

To push the host branch to origin:
  git push -u origin ${HOST_BRANCH}
"
