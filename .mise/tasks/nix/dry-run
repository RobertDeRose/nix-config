#!/usr/bin/env bash
# [MISE] description="Dry-run a nix build target or the current host config"
# [MISE] quiet=true
#
#USAGE arg "[target]" help="Flake target to dry-run (example: .#packages.aarch64-darwin.default). Defaults to the current host system target."

set -euo pipefail

TARGET="${usage_target:-}"
NIX_FLAGS=(--accept-flake-config --extra-experimental-features "nix-command flakes")

if [ -z "$TARGET" ]; then
  HOST="$(hostname -s)"
  if [ "$(uname -s)" = "Darwin" ]; then
    TARGET=".#darwinConfigurations.${HOST}.system"
  else
    TARGET=".#systemConfigs.${HOST}"
  fi
fi

echo "==> Dry-running $TARGET"
nix build "${NIX_FLAGS[@]}" --dry-run -L "$TARGET"
