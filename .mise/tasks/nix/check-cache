#!/usr/bin/env bash
# [MISE] description="Check whether a drv or output path exists in configured substituters"
# [MISE] quiet=true
#
#USAGE arg "<path>" help="A .drv path or output path under /nix/store"

# usage_* variables are injected by mise's file-task argument parser.
# shellcheck disable=SC2154

set -euo pipefail

TASK_FILE="${BASH_SOURCE[0]}"
REPO_ROOT="$(git -C "$(dirname "$TASK_FILE")" rev-parse --show-toplevel)"
cd "$REPO_ROOT"

STORE_PATH="${usage_path}"

if [[ $STORE_PATH == *.drv ]]; then
  TARGETS="$(nix derivation show "$STORE_PATH" | jq -r 'to_entries[0].value.outputs | to_entries[] | .value.path')"
else
  TARGETS="$STORE_PATH"
fi

SUBSTITUTERS="$(nix config show --json | jq -r '.substituters.value[]')"

while IFS= read -r target; do
  [ -n "$target" ] || continue
  echo "==> $target"
  while IFS= read -r store; do
    [ -n "$store" ] || continue
    if nix path-info --store "$store" "$target" > /dev/null 2>&1; then
      echo "HIT  $store"
    else
      echo "MISS $store"
    fi
  done <<< "$SUBSTITUTERS"
  echo ""
done <<< "$TARGETS"
