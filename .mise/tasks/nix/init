#!/usr/bin/env bash
# [MISE] description="Full init for a new machine: install Nix/Lix, then apply config"
# [MISE] quiet=true
# [MISE] raw=true
# [MISE] depends=["nix:trust"]
#
#USAGE arg "<hostname>" help="Hostname to assign" long_help="The hostname used as the nix config identifier. Delegates to add-host to create the host directory, then installs Nix/Lix and builds/activates the configuration. On Darwin, Homebrew is managed during nix-darwin activation."

set -euo pipefail

mise run add-host "${usage_hostname}"
mise run activate "${usage_hostname}"

echo ""
echo "Done! Open a new shell to pick up all changes."
