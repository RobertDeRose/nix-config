#!/usr/bin/env bash
# [MISE] description="Deprecated: forward to bootstrap"
# [MISE] hide=true
#
#USAGE arg "[hostname]" help="Inventory host to bootstrap"
#USAGE flag "--non-interactive" help="Disable interactive authentication"

set -euo pipefail
args=()
[ -z "${usage_hostname:-}" ] || args+=(--host "${usage_hostname}")
[ "${usage_non_interactive:-false}" != true ] || args+=(--non-interactive)
exec mise run bootstrap -- "${args[@]}"
