#!/usr/bin/env bash
# [MISE] description="Deprecated: forward to bootstrap"
# [MISE] hide=true
#
#USAGE arg "[hostname]" help="Inventory host to bootstrap"
#USAGE flag "--non-interactive" help="Disable interactive authentication"

set -euo pipefail

TASK_FILE="${BASH_SOURCE[0]}"
REPO_ROOT="$(git -C "$(dirname "$TASK_FILE")" rev-parse --show-toplevel)"
cd "$REPO_ROOT"
exec mise run bootstrap -- "$@"
