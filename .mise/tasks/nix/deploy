#!/usr/bin/env bash
# [MISE] description="Build locally and deploy system config to a remote Linux host via SSH"
# [MISE] quiet=true
#
#USAGE arg "<host>" help="SSH target (e.g. rderose@192.168.1.10 or an SSH config alias)"
#USAGE arg "[name]" help="System config name (defaults to remote hostname)"
#USAGE flag "-d --debug" help="Show verbose output and nix traces for debugging"

set -euo pipefail

TARGET_HOST="${usage_host}"
CONFIG_NAME="${usage_name:-}"
REPO_ROOT="$(git rev-parse --show-toplevel)"

# If no config name given, resolve it from the remote hostname
if [ -z "$CONFIG_NAME" ]; then
  CONFIG_NAME="$(ssh "$TARGET_HOST" hostname -s)"
  echo "==> Detected remote hostname: $CONFIG_NAME"
fi

if ! printf '%s' "$CONFIG_NAME" | grep -Eq '^[A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?$'; then
  echo "ERROR: Invalid Linux config name '$CONFIG_NAME'." >&2
  echo "       Use a single DNS-label hostname matching systems/*-linux/<name>." >&2
  exit 1
fi

HOST_PATTERN="$REPO_ROOT/systems/"*-linux/"$CONFIG_NAME"
shopt -s nullglob
HOST_DIRS=( $HOST_PATTERN )
shopt -u nullglob
HOST_DIR_COUNT=0
for _ in "${HOST_DIRS[@]}"; do
  HOST_DIR_COUNT=$((HOST_DIR_COUNT + 1))
done

if [ "$HOST_DIR_COUNT" -eq 0 ]; then
  echo "ERROR: Linux host config '$CONFIG_NAME' does not exist in this repo."
  echo ""
  echo "Expected to find a host directory matching:"
  echo "  systems/*-linux/$CONFIG_NAME"
  echo ""
  echo "Add it first, for example:"
  echo "  mise run add-host $CONFIG_NAME linux aarch64"
  echo "  # or"
  echo "  mise run add-host $CONFIG_NAME linux x86_64"
  exit 1
fi

if [ "$HOST_DIR_COUNT" -ne 1 ]; then
  echo "ERROR: Linux host config '$CONFIG_NAME' matched multiple host directories." >&2
  printf '  %s\n' "${HOST_DIRS[@]}" >&2
  echo "Choose a unique hostname under systems/*-linux/." >&2
  exit 1
fi

HOST_DIR="${HOST_DIRS[0]}"
USER_NIX="$HOST_DIR/user.nix"
HM_USER="$(nix eval --impure --raw --expr "let user = import ${USER_NIX}; in user.username")"
GITHUB_USERNAME="$(nix eval --impure --raw --expr "let user = import ${USER_NIX}; in user.githubUsername")"

if [ -z "$HM_USER" ]; then
  echo "ERROR: Could not determine username from $USER_NIX"
  exit 1
fi

if [ "$HM_USER" = "root" ]; then
  echo "ERROR: Refusing to deploy Home Manager for reserved user 'root'."
  echo "       Set user.username in $USER_NIX to the managed non-root account."
  exit 1
fi

if [ -z "$GITHUB_USERNAME" ]; then
  echo "ERROR: Could not determine githubUsername from $USER_NIX"
  exit 1
fi

if ! printf '%s' "$HM_USER" | grep -Eq '^[a-z_][a-z0-9_-]*$'; then
  echo "ERROR: Invalid managed username '$HM_USER' in $USER_NIX"
  echo "       Use a portable POSIX account name for deploy-time shell commands."
  exit 1
fi

if ! printf '%s' "$GITHUB_USERNAME" | grep -Eq '^[A-Za-z0-9]([A-Za-z0-9-]{0,37}[A-Za-z0-9])?$'; then
  echo "ERROR: Invalid githubUsername '$GITHUB_USERNAME' in $USER_NIX"
  echo "       GitHub usernames must be 1-39 alphanumeric or hyphen characters and cannot start or end with a hyphen."
  exit 1
fi

echo "==> Host '$CONFIG_NAME' will use GitHub SSH keys from: $GITHUB_USERNAME"
echo "==> Checking GitHub SSH keys for $GITHUB_USERNAME..."
if ! KEYS="$(curl -fsSL --connect-timeout 5 --max-time 10 "https://github.com/$GITHUB_USERNAME.keys")"; then
  echo "ERROR: Failed to fetch GitHub SSH keys for $GITHUB_USERNAME"
  echo "       Ensure the username is correct and GitHub is reachable before first deploy."
  exit 1
fi

if [ -z "$KEYS" ]; then
  echo "ERROR: GitHub user '$GITHUB_USERNAME' has no public SSH keys."
  echo "       Add at least one SSH key to https://github.com/settings/keys before first deploy."
  exit 1
fi

NIX_FLAGS=(--accept-flake-config --extra-experimental-features "nix-command flakes")
if [[ "${usage_debug:-}" == "true" ]]; then
  NIX_FLAGS+=("--show-trace" "--verbose")
fi

SYSTEM_FLAKE_REF=".#systemConfigs.\"$CONFIG_NAME\""
HOME_ACTIVATION_REF=".#homeConfigurations.\"$CONFIG_NAME\".activationPackage"

if ! nix eval "${NIX_FLAGS[@]}" --raw "$HOME_ACTIVATION_REF.type" >/dev/null 2>&1; then
  echo "ERROR: Home Manager configuration '$CONFIG_NAME' does not exist in this repo."
  echo "       Expected flake target: $HOME_ACTIVATION_REF"
  exit 1
fi

echo "==> Checking Nix on remote host..."
if ! ssh -o BatchMode=yes -o ConnectTimeout=5 "$TARGET_HOST" true 2>/dev/null; then
  ssh-copy-id "$TARGET_HOST"
fi

if ! ssh "$TARGET_HOST" 'command -v nix >/dev/null 2>&1 && command -v nix-store >/dev/null 2>&1'; then
  echo "==> Nix not found on $TARGET_HOST. Installing Lix..."
  ssh -t "$TARGET_HOST" "bash -c 'set -euo pipefail

SUDO=()
if [ "$(id -u)" -ne 0 ]; then
  if ! command -v sudo >/dev/null 2>&1; then
    echo "ERROR: Remote bootstrap requires root or sudo for privileged setup." >&2
    exit 1
  fi
  SUDO=(sudo)
  "${SUDO[@]}" -v
fi

if ! command -v nix >/dev/null 2>&1; then
  export NIX_INSTALLER_NO_CONFIRM=true
  export NIX_INSTALLER_ENABLE_FLAKES=true
  curl -sSfL https://install.lix.systems/lix | sh -s -- install
fi

"${SUDO[@]}" mkdir -p /usr/local/bin
"${SUDO[@]}" ln -sf /nix/var/nix/profiles/default/bin/nix-store /usr/local/bin/nix-store
"${SUDO[@]}" ln -sf /nix/var/nix/profiles/default/bin/nix /usr/local/bin/nix
"${SUDO[@]}" systemctl restart nix-daemon.socket 2>/dev/null || true
"${SUDO[@]}" systemctl restart nix-daemon.service 2>/dev/null || true

for i in $(seq 1 30); do
  [ -S /nix/var/nix/daemon-socket/socket ] && break
  sleep 1
done

set +u
source /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh
set -u

nix --version >/dev/null
nix-store --version >/dev/null
'"
  echo "==> Nix tooling is ready on $TARGET_HOST."
fi

SSH_USER="$(ssh -G "$TARGET_HOST" | sed -n 's/^user //p' | head -n 1)"

echo "==> Ensuring remote Nix trusts SSH user '$SSH_USER'..."
ssh -t "$TARGET_HOST" '
set -eu

TRUSTED_USER="$(id -un)"
CONF="/etc/nix/nix.conf"

run_root() {
  if [ "$(id -u)" -eq 0 ]; then
    "$@"
  else
    sudo "$@"
  fi
}

if [ "$(id -u)" -ne 0 ]; then
  if ! command -v sudo >/dev/null 2>&1; then
    echo "ERROR: Remote Nix trust setup requires root or sudo." >&2
    exit 1
  fi
  sudo -v
fi

run_root mkdir -p /etc/nix
run_root touch "$CONF"

if ! grep -qE "^(extra-)?trusted-users[[:space:]]*=.*(^|[[:space:]])${TRUSTED_USER}([[:space:]]|$)" "$CONF" 2>/dev/null; then
  if grep -qE "^extra-trusted-users[[:space:]]*=" "$CONF" 2>/dev/null; then
    run_root sed -i "s/^extra-trusted-users[[:space:]]*=.*/& ${TRUSTED_USER}/" "$CONF"
  else
    printf "extra-trusted-users = %s\n" "$TRUSTED_USER" | run_root tee -a "$CONF" >/dev/null
  fi
fi

if ! grep -q "robertderose.cachix.org" "$CONF" 2>/dev/null; then
  printf "%s\n%s\n" \
    "extra-substituters = https://robertderose.cachix.org https://cache.numtide.com https://cache.nixos.org https://nix-community.cachix.org" \
    "extra-trusted-public-keys = cache.nixos.org-1:6NCHdD59X431o0gWypbMrAURkbJ16ZPMQFGspcDShjY= nix-community.cachix.org-1:mB9FSh9qf2dCimDSUo8Zy7bkq5CX+/rkCWyvRCYg3Fs= niks3.numtide.com-1:DTx8wZduET09hRmMtKdQDxNNthLQETkc/yaX7M4qK0g= robertderose.cachix.org-1:LGSby4A1Kg1W19IC5AoB3oGhLSgfg1x3j2GF0Ve2hKM=" \
    | run_root tee -a "$CONF" >/dev/null
fi

run_root systemctl restart nix-daemon.socket 2>/dev/null || true
run_root systemctl restart nix-daemon.service 2>/dev/null || true
'

echo "==> Building system-manager from flake..."
nix build "${NIX_FLAGS[@]}" ".#system-manager" --out-link "$REPO_ROOT/result"

SYSTEM_MANAGER_ARGS=(
  --target-host "$TARGET_HOST"
  switch
  --flake "$SYSTEM_FLAKE_REF"
)
if [ "$SSH_USER" != "root" ]; then
  SYSTEM_MANAGER_ARGS+=(--ask-sudo-password)
fi

echo "==> Deploying system config '$CONFIG_NAME' to $TARGET_HOST..."
"$REPO_ROOT/result/bin/system-manager" "${SYSTEM_MANAGER_ARGS[@]}"

echo "==> Building home-manager activation for '$CONFIG_NAME'..."
nix build "${NIX_FLAGS[@]}" "$HOME_ACTIVATION_REF" --out-link "$REPO_ROOT/.hm-result"
HM_STORE_PATH="$(nix path-info "${NIX_FLAGS[@]}" "$HOME_ACTIVATION_REF")"

echo "==> Activating home-manager for '$HM_USER' on $TARGET_HOST..."
nix copy "${NIX_FLAGS[@]}" --to "ssh://$TARGET_HOST" "$HM_STORE_PATH"
ssh "$TARGET_HOST" sh -s -- "$HM_USER" "$HM_STORE_PATH/activate" <<'EOF'
set -eu

ACTIVATE_USER="$1"
HM_ACTIVATE="$2"
CURRENT_USER="$(id -un)"
ACTIVATE_HOME="$(getent passwd "$ACTIVATE_USER" | cut -d: -f6)"
ACTIVATE_PATH="/nix/var/nix/profiles/default/bin:/run/current-system/sw/bin:$PATH"

if [ -z "$ACTIVATE_HOME" ]; then
  ACTIVATE_HOME="/home/$ACTIVATE_USER"
fi

if [ "$CURRENT_USER" = "root" ]; then
  install -d -m755 -o "$ACTIVATE_USER" -g "$(id -gn "$ACTIVATE_USER")" "/nix/var/nix/profiles/per-user/$ACTIVATE_USER"
elif [ "$CURRENT_USER" != "$ACTIVATE_USER" ]; then
  sudo install -d -m755 -o "$ACTIVATE_USER" -g "$(id -gn "$ACTIVATE_USER")" "/nix/var/nix/profiles/per-user/$ACTIVATE_USER"
fi

if [ "$CURRENT_USER" = "$ACTIVATE_USER" ]; then
  env USER="$ACTIVATE_USER" HOME="$ACTIVATE_HOME" PATH="$ACTIVATE_PATH" HOME_MANAGER_BACKUP_EXT=hm_bak "$HM_ACTIVATE"
elif [ "$CURRENT_USER" = "root" ]; then
  if command -v runuser >/dev/null 2>&1; then
    runuser -u "$ACTIVATE_USER" -- env USER="$ACTIVATE_USER" HOME="$ACTIVATE_HOME" PATH="$ACTIVATE_PATH" HOME_MANAGER_BACKUP_EXT=hm_bak "$HM_ACTIVATE"
  else
    su -s /bin/sh "$ACTIVATE_USER" -c "USER='$ACTIVATE_USER' HOME='$ACTIVATE_HOME' PATH='$ACTIVATE_PATH' HOME_MANAGER_BACKUP_EXT=hm_bak '$HM_ACTIVATE'"
  fi
else
  sudo -u "$ACTIVATE_USER" env USER="$ACTIVATE_USER" HOME="$ACTIVATE_HOME" PATH="$ACTIVATE_PATH" HOME_MANAGER_BACKUP_EXT=hm_bak "$HM_ACTIVATE"
fi
EOF
