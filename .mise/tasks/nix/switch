#!/usr/bin/env bash
# [MISE] description="Deprecated: forward to apply"
# [MISE] hide=true
#
#USAGE flag "-d --debug" help="Show verbose Nix output and traces"
#USAGE flag "--host <host>" help="Host to apply"
#USAGE flag "--no-activate" help="Build without activation"

set -euo pipefail

TASK_FILE="${BASH_SOURCE[0]}"
REPO_ROOT="$(git -C "$(dirname "$TASK_FILE")" rev-parse --show-toplevel)"
cd "$REPO_ROOT"
exec mise run apply -- "$@"
