#!/usr/bin/env bash
# [MISE] description="Garbage-collect all unused nix store entries (system + user)"
# [MISE] interactive=true
# [MISE] quiet=true
#
#USAGE arg "[older_than]" help="Retention window (examples: 7d, 30d, 4w)" default="7d"

set -euo pipefail

TASK_FILE="${BASH_SOURCE[0]}"
REPO_ROOT="$(git -C "$(dirname "$TASK_FILE")" rev-parse --show-toplevel)"
cd "$REPO_ROOT"

OLDER_THAN="${usage_older_than:-7d}"

sudo nix-collect-garbage --delete-older-than "$OLDER_THAN"
nix-collect-garbage --delete-older-than "$OLDER_THAN"
