#!/usr/bin/env bash
# [MISE] description="Re-export iTerm2 preferences plist into the repo"
# [MISE] quiet=true

set -euo pipefail

TASK_FILE="${BASH_SOURCE[0]}"
REPO_ROOT="$(git -C "$(dirname "$TASK_FILE")" rev-parse --show-toplevel)"
cd "$REPO_ROOT"

if [ "$(uname -s)" != "Darwin" ]; then
  echo "ERROR: iterm:export is macOS-only."
  exit 1
fi

SRC="$HOME/Library/Preferences/com.googlecode.iterm2.plist"
DST="config/iterm2/com.googlecode.iterm2.plist"

if [ ! -e "$SRC" ]; then
  echo "ERROR: iTerm2 preferences not found at $SRC"
  exit 1
fi

echo "==> Copying iTerm2 plist into repo..."
cp "$SRC" "$DST"
echo "    Exported to $DST"
echo ""
echo "Review with: git diff --stat"
echo "Then commit: git add -A && git commit -m 'chore: update iTerm2 preferences'"
