#!/usr/bin/env -S usage bash
# Maison is a thin, location-independent interface to the repository's mise tasks.
#
#USAGE about "Put your workstation in order."
#USAGE long_about "Maison is a mise-driven workstation configuration manager for macOS and Linux."
#USAGE flag "-V --version" help="Show the installed Maison revision"
#USAGE cmd "activate" help="Activate Maison shell integration" { arg "[args]..." }
#USAGE cmd "apply" help="Build and apply the selected host" { arg "[args]..." }
#USAGE cmd "bootstrap" help="Bootstrap or repair a host" { arg "[args]..." }
#USAGE cmd "deploy" help="Deploy a Linux host over SSH" { arg "[args]..." }
#USAGE cmd "doctor" help="Diagnose local configuration problems" { arg "[args]..." }
#USAGE cmd "plan" help="Preview configuration changes" { arg "[args]..." }
#USAGE cmd "rollback" help="Roll back the selected host" { arg "[args]..." }
#USAGE cmd "update" help="Update flake inputs and validate the result" { arg "[args]..." }
#USAGE cmd "tasks" help="List Maison tasks" { arg "[args]..." }
#USAGE cmd "completion" help="Generate the Usage shell initialization" {
#USAGE   arg "<shell>" { choices "bash" "zsh" "fish" }
#USAGE }
#USAGE cmd "github" help="Manage GitHub authentication" subcommand_required=#true {
#USAGE   cmd "auth" help="Configure GitHub API authentication" { arg "[args]..." }
#USAGE }
#USAGE cmd "app" help="Manage applications" subcommand_required=#true {
#USAGE   cmd "add" help="Add an application" { arg "[args]..." }
#USAGE   cmd "remove" help="Remove an application" { arg "[args]..." }
#USAGE }
#USAGE cmd "cache" help="Manage the binary cache" subcommand_required=#true {
#USAGE   cmd "package" help="Cache a package" { arg "[args]..." }
#USAGE   cmd "status" help="Show cache status" { arg "[args]..." }
#USAGE }
#USAGE cmd "docs" help="Manage documentation" subcommand_required=#true {
#USAGE   cmd "build" help="Build documentation" { arg "[args]..." }
#USAGE   cmd "serve" help="Serve documentation" { arg "[args]..." }
#USAGE }
#USAGE cmd "host" help="Manage hosts" subcommand_required=#true {
#USAGE   cmd "add" help="Add a host" { arg "[args]..." }
#USAGE   cmd "list" help="List hosts" { arg "[args]..." }
#USAGE   cmd "validate" help="Validate hosts" { arg "[args]..." }
#USAGE }
#USAGE cmd "iterm" help="Manage iTerm configuration" subcommand_required=#true {
#USAGE   cmd "export" help="Export iTerm configuration" { arg "[args]..." }
#USAGE }
#USAGE cmd "nix" help="Manage Nix" subcommand_required=#true {
#USAGE   cmd "clean" help="Clean Nix build artifacts" { arg "[args]..." }
#USAGE   cmd "debug" help="Debug Nix configuration" { arg "[args]..." }
#USAGE   cmd "deploy" help="Deploy with Nix" { arg "[args]..." }
#USAGE   cmd "dry-run" help="Preview a Nix operation" { arg "[args]..." }
#USAGE   cmd "fmt" help="Format Nix files" { arg "[args]..." }
#USAGE   cmd "gc" help="Run Nix garbage collection" { arg "[args]..." }
#USAGE   cmd "gcroot" help="Manage Nix GC roots" { arg "[args]..." }
#USAGE   cmd "history" help="Show Nix generation history" { arg "[args]..." }
#USAGE   cmd "init" help="Initialize Nix" { arg "[args]..." }
#USAGE   cmd "repl" help="Open a Nix REPL" { arg "[args]..." }
#USAGE   cmd "switch" help="Switch Nix generations" { arg "[args]..." }
#USAGE   cmd "trust" help="Manage trusted Nix users" { arg "[args]..." }
#USAGE   cmd "uninstall" help="Uninstall Nix" { arg "[args]..." }
#USAGE   cmd "up" help="Update Nix inputs" { arg "[args]..." }
#USAGE }
#USAGE cmd "package" help="Manage packages" subcommand_required=#true {
#USAGE   cmd "add" help="Add a package" { arg "[args]..." }
#USAGE   cmd "remove" help="Remove a package" { arg "[args]..." }
#USAGE   cmd "search" help="Search package sources" { arg "[args]..." }
#USAGE   cmd "validate" help="Validate package ownership" { arg "[args]..." }
#USAGE }
#USAGE cmd "test" help="Run integration tests" subcommand_required=#true {
#USAGE   cmd "bootstrap" help="Test bootstrap" { arg "[args]..." }
#USAGE   cmd "deploy" help="Test deployment" { arg "[args]..." }
#USAGE   cmd "image" help="Build the test image" { arg "[args]..." }
#USAGE }
#USAGE cmd "tool" help="Manage global mise tools" subcommand_required=#true {
#USAGE   cmd "add" help="Add a global tool" { arg "[args]..." }
#USAGE   cmd "remove" help="Remove a global tool" { arg "[args]..." }
#USAGE }
#USAGE cmd "github-auth" hide=#true { arg "[args]..." }
#USAGE cmd "add-host" hide=#true { arg "[args]..." }
#USAGE cmd "install-nix" hide=#true { arg "[args]..." }
#USAGE cmd "__task-names" hide=#true
#USAGE cmd "__command-paths" hide=#true

set -euo pipefail

log_error() {
  printf 'maison: %s\n' "$*" >&2
}

die() {
  log_error "$*"
  exit 1
}

maison_home="${MAISON_HOME:-${NIX_CONFIG_DIR:-$HOME/.maison}}"

if [ ! -d "$maison_home" ]; then
  die "installation not found at $maison_home; set MAISON_HOME or rerun bootstrap"
fi
if [ ! -f "$maison_home/mise.toml" ] || [ ! -f "$maison_home/flake.nix" ]; then
  die "$maison_home does not look like a Maison installation"
fi

if command -v mise > /dev/null 2>&1; then
  mise_bin="$(command -v mise)"
elif [ -x "$HOME/.local/bin/mise" ]; then
  mise_bin="$HOME/.local/bin/mise"
else
  die "mise is unavailable; rerun Maison bootstrap"
fi

export MISE_TRUSTED_CONFIG_PATHS="$maison_home${MISE_TRUSTED_CONFIG_PATHS:+:$MISE_TRUSTED_CONFIG_PATHS}"

list_task_names() {
  find "$maison_home/.mise/tasks" -type f -perm -u+x -print \
    | sed "s#^$maison_home/.mise/tasks/##; s#/#:#g" \
    | LC_ALL=C sort -u
}

list_public_task_names() {
  local task compatibility
  while IFS= read -r task; do
    compatibility="${task//-/:}"
    if [ "$compatibility" != "$task" ] && list_task_names | grep -Fxq "$compatibility"; then
      continue
    fi
    printf '%s\n' "$task"
  done < <(list_task_names)
}

list_command_paths() {
  list_public_task_names | tr ':' ' '
}

resolve_task() {
  local -a words=("$@")
  local candidate="" best="" index best_count=0 task

  for ((index = 0; index < ${#words[@]}; index++)); do
    if [ -z "$candidate" ]; then
      candidate="${words[index]}"
    else
      candidate+="${candidate:+:}${words[index]}"
    fi

    while IFS= read -r task; do
      if [ "$candidate" = "$task" ]; then
        best="$task"
        best_count=$((index + 1))
        break
      fi
    done < <(list_task_names)
  done

  [ -n "$best" ] || return 1
  printf '%s\t%s\n' "$best" "$best_count"
}

show_help() {
  cat <<'HELP'
Maison — put your workstation in order

Usage:
  maison <command> [subcommand...] [arguments...]
  maison help [command] [subcommand...]
  maison tasks
  maison completion <bash|zsh|fish>
  maison --version

Common tasks:
  doctor                 Diagnose local configuration problems
  plan                   Preview configuration changes
  apply                  Build and apply the selected host
  check                  Validate Maison and every configured host
  update                 Update flake inputs and validate the result
  bootstrap              Bootstrap or repair a host
  deploy                 Deploy a Linux host over SSH
  github auth            Configure GitHub API authentication
  package search         Search package sources

Task help and argument parsing are generated from each task's #USAGE metadata:
  maison help package search
  maison package search --help

Shell completion is generated specifically for Maison through Usage.

Run `maison tasks` for the complete task list.
HELP
}

case "${1:-}" in
  "" | -h | --help)
    show_help
    exit 0
    ;;
  -V | --version)
    if git -C "$maison_home" rev-parse --short HEAD > /dev/null 2>&1; then
      printf 'maison %s\n' "$(git -C "$maison_home" rev-parse --short HEAD)"
    else
      printf 'maison unknown\n'
    fi
    exit 0
    ;;
  help)
    shift
    if [ "$#" -eq 0 ]; then
      show_help
      exit 0
    fi
    resolution="$(resolve_task "$@" || true)"
    [ -n "$resolution" ] || die "unknown command '$*'"
    task="${resolution%%$'\t'*}"
    cd "$maison_home"
    if [ "$task" = github:auth ] || [ "$task" = bootstrap ]; then
      exec "$mise_bin" run --skip-tools "$task" --help
    fi
    exec "$mise_bin" run "$task" --help
    ;;
  tasks)
    shift
    cd "$maison_home"
    exec "$mise_bin" tasks "$@"
    ;;
  completion)
    [ "$#" -eq 2 ] || die "usage: maison completion <bash|zsh|fish>"
    exec usage generate completion "$2" maison -f "$maison_home/bin/maison"
    ;;
  __task-names)
    list_task_names
    exit 0
    ;;
  __command-paths)
    list_command_paths
    exit 0
    ;;
esac

resolution="$(resolve_task "$@" || true)"
[ -n "$resolution" ] || die "unknown command '$*'; run 'maison tasks' to list commands"
task="${resolution%%$'\t'*}"
consumed="${resolution##*$'\t'}"
shift "$consumed"

cd "$maison_home"
run_task() {
  local output_file status
  local -a command=("$mise_bin" run)

  if [ "$task" = github:auth ] || [ "$task" = bootstrap ]; then
    command+=(--skip-tools)
  fi
  command+=("$task" -- "$@")

  output_file="$(mktemp "${TMPDIR:-/tmp}/maison-output.XXXXXX")"

  set +e
  "${command[@]}" > >(tee "$output_file") 2> >(tee -a "$output_file" >&2)
  status=$?
  set -e

  if grep -Eqi 'rate limit exceeded|API rate limit|HTTP error 403|403 Forbidden|No GitHub token' "$output_file"; then
    printf '\nmaison: GitHub authentication is required or the API rate limit was exceeded.\n' >&2
    printf 'Run: maison github auth\n' >&2
  fi

  rm -f "$output_file"
  return "$status"
}

run_task "$@"
