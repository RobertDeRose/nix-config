# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
charset = utf-8
end_of_line = lf
indent_size = 2
indent_style = space
insert_final_newline = true

[[shell]]
binary_next_line   = false
function_next_line = false
keep_padding       = false
minify             = false
shell_variant      = bash
simplify           = true
space_redirects    = true
switch_case_indent = true
